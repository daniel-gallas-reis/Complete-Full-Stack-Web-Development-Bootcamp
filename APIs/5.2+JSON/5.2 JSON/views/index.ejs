<!DOCTYPE html>
<html>

<head>
  <title>Taco Recipes</title>
  <link rel="stylesheet" type="text/css" href="/styles/main.css">
</head>

<body>
  <h1>Taco Town 🌮</h1>

  <form action="/recipe" method="POST" class="buttons">
    <button type="submit" value="chicken" name="choice">🍗</button>
    <button type="submit" value="beef" name="choice">🥩</button>
    <button type="submit" value="fish" name="choice">🐟</button>
  </form>
  <div id="recipeContainer" class="hidden">

    <!-- If no recipe yet, show: -->
    <% if (!locals.data) { %>
      <h2>Pick your favourite taco ingredient 👆</h2>
      <% }else{ %>
        <h2>
          <%= data.name %>
        </h2>
        <% } %>
          <!-- Else, show the recipe name e.g. <h2>Recipe name</h2>-->
          <h3>Ingredients:</h3>
          <ul id="ingredientsList">
            <% if (!locals.data) { %>
              <li>Protein name, protein preparation</li>
            <% }else{ %>
                <li>
                  <%= data.ingredients.protein.name %>, <%= data.ingredients.protein.preparation %>
                </li>
            <% } %>
            <% if (!locals.data) { %>
              <li>Salsa name</li>
            <% }else{ %>
                <li>
                  <%= data.ingredients.salsa.name %>
                </li>
            <% } %>
            <% if (!locals.data) { %>
              <li>Every other topping</li>
            <% }else{ %>
              <% for (let index=0; index < data.ingredients.toppings.length; index++) { %>
                  <li>
                    <%= data.ingredients.toppings[index].name %>
                  </li>
              <% } %>
              <% } %>
          </ul>
  </div>
</body>

</html>